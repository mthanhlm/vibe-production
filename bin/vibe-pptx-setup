#!/usr/bin/env bash
# vibe-pptx-setup — install/probe the global python-pptx toolkit for deck
# building. Creates a venv and pip-installs python-pptx ONLY — no other
# packages, no config writes, no prompts: consent is conversational and
# belongs to the skills (WA-12/WA-14). Idempotent: once the venv imports
# pptx, reruns make zero pip calls.
#
#   VIBE_PPTX_DIR   toolkit home (default ~/.claude/vibe-pptx)
#
# Output (WA-15): exactly one machine-parseable decision line on stdout
#   PPTX: ready|no-python3|venv-failed|install-failed
# with actionable detail on stderr when not ready.
set -u

PPTX_DIR="${VIBE_PPTX_DIR:-$HOME/.claude/vibe-pptx}"

[ $# -eq 0 ] || {
  echo "vibe-pptx-setup: unknown argument: $1 (no flags supported)" >&2; exit 2; }

command -v python3 >/dev/null 2>&1 || {
  echo "vibe-pptx-setup: python3 not found on PATH — install Python 3, then re-run." >&2
  echo "PPTX: no-python3"; exit 1; }

if [ ! -x "$PPTX_DIR/bin/python" ]; then
  mkdir -p "$PPTX_DIR" || {
    echo "vibe-pptx-setup: could not create $PPTX_DIR — check permissions/disk." >&2
    echo "PPTX: venv-failed"; exit 1; }
  python3 -m venv "$PPTX_DIR" || {
    echo "vibe-pptx-setup: venv creation failed — on Debian/Ubuntu: sudo apt install python3-venv, then re-run." >&2
    echo "PPTX: venv-failed"; exit 1; }
fi

if ! "$PPTX_DIR/bin/python" -c "import pptx" 2>/dev/null; then
  timeout 300 "$PPTX_DIR/bin/pip" install --quiet 'python-pptx<2' || {
    echo "vibe-pptx-setup: pip install python-pptx failed (offline? registry blocked?) — fix and re-run." >&2
    echo "PPTX: install-failed"; exit 1; }
  "$PPTX_DIR/bin/python" -c "import pptx" 2>/dev/null || {
    echo "vibe-pptx-setup: python-pptx installed but does not import — delete $PPTX_DIR and re-run." >&2
    echo "PPTX: install-failed"; exit 1; }
fi

echo "PPTX: ready"
